﻿@model WebApp.Models.ApiConfig
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
         <!--服务名-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.ServiceName)</label>
			@Html.EditorFor(x => x.ServiceName, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.ServiceName) } })
      
         </div>

        <!--主机地址-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Host)</label>
			@Html.EditorFor(x => x.Host, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Host) } })
      
         </div>

        <!--安全代码-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.SecretAccessKey)</label>
			@Html.EditorFor(x => x.SecretAccessKey, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.SecretAccessKey) } })
      
         </div>

        <!--访问代码-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.AccessKeyId)</label>
			@Html.EditorFor(x => x.AccessKeyId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.AccessKeyId) } })
      
         </div>

        <!--登录用户名-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.UserId)</label>
			@Html.EditorFor(x => x.UserId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.UserId) } })
      
         </div>

        <!--登录密码-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Password)</label>
			@Html.EditorFor(x => x.Password, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Password) } })
      
         </div>

        <!--描述-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Description)</label>
			@Html.EditorFor(x => x.Description, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Description) } })
      
         </div>

     
       <!--所属企业-->
       <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.CompanyId)</label>
   	        @Html.DropDownListFor(model => model.CompanyId, ViewBag.CompanyId as List<SelectListItem>, htmlAttributes: new { @class = "form-control" }) 
       </div>

	    
</div>

