﻿@model WebApp.Models.Customer
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
         <!--单位名称-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Name)</label>
			@Html.EditorFor(x => x.Name, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Name) } })
      
         </div>

        <!--单位层级-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Level)</label>
			@Html.EditorFor(x => x.Level, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Level) } })
      
         </div>

        <!--管理部门-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Dept)</label>
			@Html.EditorFor(x => x.Dept, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Dept) } })
      
         </div>

        <!--主要联系人-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Contact)</label>
			@Html.EditorFor(x => x.Contact, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Contact) } })
      
         </div>

        <!--联系方式-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.ContactInfo)</label>
			@Html.EditorFor(x => x.ContactInfo, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.ContactInfo) } })
      
         </div>

        <!--短信通知手机号-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.MobilePhone)</label>
			@Html.EditorFor(x => x.MobilePhone, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.MobilePhone) } })
      
         </div>

		<!--用水定额(月)-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Quota)</label>
            @Html.EditorFor(x => x.Quota, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Quota) } })

        </div>

		<!--预警阈值-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Threshold)</label>
            @Html.EditorFor(x => x.Threshold, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Threshold) } })

        </div>

		
      <!--是否计费-->
      <div class="col-xs-12 col-md-6">
              <label class="form-label text-danger">@Html.DisplayNameFor(model => model.IsFee)</label>
              <div class="custom-control custom-checkbox">
                 <input id="@Html.IdFor(model => model.IsFee)"
                       name="@Html.NameFor(model => model.IsFee)"
                       value="true" @(Model.IsFee ? "checked=\"checked\"" : "")
                       class="custom-control-input"
                       tabindex="6"
                       type="checkbox" />
                <label class="custom-control-label" for="@Html.IdFor(model => model.IsFee)">@Html.DisplayNameFor(model => model.IsFee)</label>
            </div>
      </div>

		<!--折扣-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Discount)</label>
            @Html.EditorFor(x => x.Discount, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Discount) } })

        </div>

       <!--注册日期-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.RegisterDate)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.RegisterDate, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.RegisterDate ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

        <!--备注-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Remark)</label>
			@Html.EditorFor(x => x.Remark, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Remark) } })
      
         </div>

	    
</div>

