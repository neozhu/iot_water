﻿@model WebApp.Models.OrgChart
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
         <!--总序号-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label">  @Html.DisplayNameFor(model => model.No)</label>
			@Html.EditorFor(x => x.No, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.No) } })
      
         </div>

        <!--层级-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label"> <span class="text-danger">*</span> @Html.DisplayNameFor(model => model.Level)</label>
			@Html.EditorFor(x => x.Level, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Level) } })
      
         </div>

        <!--层级序号-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label"> <span class="text-danger">*</span> @Html.DisplayNameFor(model => model.LevelNo)</label>
			@Html.EditorFor(x => x.LevelNo, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.LevelNo) } })
      
         </div>

        <!--位置-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label">  @Html.DisplayNameFor(model => model.Location)</label>
			@Html.EditorFor(x => x.Location, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Location) } })
      
         </div>

        <!--精度-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label">  @Html.DisplayNameFor(model => model.Precision)</label>
			@Html.EditorFor(x => x.Precision, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Precision) } })
      
         </div>

        <!--口径-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label">  @Html.DisplayNameFor(model => model.DN)</label>
			@Html.EditorFor(x => x.DN, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.DN) } })
      
         </div>

        <!--年份-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label">  @Html.DisplayNameFor(model => model.Year)</label>
			@Html.EditorFor(x => x.Year, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Year) } })
      
         </div>

        <!--备注-->
        <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label">  @Html.DisplayNameFor(model => model.Remark)</label>
			@Html.EditorFor(x => x.Remark, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Remark) } })
      
         </div>

     
       <!--父级-->
       <div class="col-xs-12 col-sm-6 col-md-4 col-lg-3">
            <label class="form-label">  @Html.DisplayNameFor(model => model.ParentId)</label>
   	        @Html.DropDownListFor(model => model.ParentId, ViewBag.ParentId as List<SelectListItem>, htmlAttributes: new { @class = "form-control" }) 
       </div>

	    
</div>

