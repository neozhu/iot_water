﻿@model WebApp.Models.WaterManualReport
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
         <!--表号-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.meterId)</label>
			@Html.EditorFor(x => x.meterId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.meterId) } })
      
         </div>

        <!--表名-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Name)</label>
			@Html.EditorFor(x => x.Name, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Name) } })
      
         </div>

        <!--表序号-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.LineNo)</label>
			@Html.EditorFor(x => x.LineNo, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.LineNo) } })
      
         </div>

        <!--出线名称-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Name1)</label>
			@Html.EditorFor(x => x.Name1, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Name1) } })
      
         </div>

		<!--本期读数-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Water)</label>
            @Html.EditorFor(x => x.Water, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Water) } })

        </div>

       <!--抄表日期-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.RecordDate)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.RecordDate, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.RecordDate ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

		<!--上期读数-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.LastWater)</label>
            @Html.EditorFor(x => x.LastWater, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.LastWater) } })

        </div>

       <!--上期抄表日期-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.LastRecordDate)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.LastRecordDate, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.LastRecordDate ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

		<!--本期用水量-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.CalWater)</label>
            @Html.EditorFor(x => x.CalWater, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.CalWater) } })

        </div>

        <!--备注-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Remark)</label>
			@Html.EditorFor(x => x.Remark, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Remark) } })
      
         </div>

	    
</div>

