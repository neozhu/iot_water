﻿@model WebApp.Models.Department
<!-- 弹出窗体form表单 -->
  <div id="departmentdetailwindow" class="easyui-window"
       title="明细数据"
       data-options="modal:true,
                    closed:true,
                    minimizable:false,
                    collapsible:false,
                    maximized:false,
                    iconCls:'icon-more',
                    footer:'#windowfooter',
                    closeDuration:200,
                    closeAnimation:'slide',
                    openDuration:300,
                    openAnimation:'slide',
                    onBeforeClose:function(){
                      var that = $(this);
                      if(departmenthasmodified()){
                        $.messager.confirm('确认','你确定要放弃保存修改的记录?',function(r){
                        if (r){
                          var opts = that.panel('options');
                          var onBeforeClose = opts.onBeforeClose;
                          opts.onBeforeClose = function(){};
                          that.panel('close');
                          opts.onBeforeClose = onBeforeClose;
                          hook = false;
                        }
                        });
                        return false;
                      }
                    },
                    onOpen:function(){
                       $(this).window('vcenter');
                       $(this).window('hcenter');
                    },
                    onRestore:function(){
                    },
                    onMaximize:function(){
                    }
                    " style="width:820px;height:420px;display:none">
    <div class="panel-content py-2 rounded-bottom border-faded border-left-0 border-right-0  text-muted">
      <div class="row m-0">
        <div class="col-sm-8">
          <div class="btn-group btn-group-sm">
            <button name="saveitembutton" onclick="savedepartmentitem()" class="btn btn-default">
              <i class="fa fa-floppy-o"></i> @Html.L("Save")
            </button>
          </div>
          <div class="btn-group btn-group-sm" id="deleteitem-btn-group">
            <button onclick="deletedepartmentitem()" class="btn btn-danger">
              <i class="fa fa-trash-o"></i> @Html.L("Delete")
            </button>
          </div>
          <div class="btn-group btn-group-sm" style="display:none">
            <button onclick="todo()" class="btn btn-default">
              <i class="fa fa-print"></i> ToDo
            </button>
          </div>
        </div>
        <div class="col-sm-4 text-align-right">

        </div>
      </div>
    </div>
    <!-- panel form -->
    <div class="panel-content">
      <form id="department_form"
            class="easyui-form form-horizontal p-1"
            method="post"
            data-options="novalidate:true,
                            onChange: function(target){
                              hook = true;
                              $('button[name*=\'saveitembutton\']').prop('disabled', false);
                             },
                             onLoadSuccess:function(data){
                               hook = false;
                               $('button[name*=\'saveitembutton\']').prop('disabled', true);
                             }">
        @Html.AntiForgeryToken()
        <!--Primary Key-->
        @Html.HiddenFor(model => model.Id)
        <fieldset class="form-group">
          <div class="row m-1">
            <!--部门名称-->
            <label class="col-md-1 form-label text-right text-danger">@Html.DisplayNameFor(model => model.Name)</label>
            <div class="col-md-3 mb-1">
              <input id="@Html.IdFor(model => model.Name)"
                     name="@Html.NameFor(model => model.Name)"
                     value="@Html.ValueFor(model => model.Name)"
                     tabindex="0" required
                     class="easyui-textbox"
                     style="width:100%"
                     type="text"
                     data-options="prompt:'@Html.DisplayNameFor(model => model.Name)',
								        required:true, validType: 'length[0,50]'
                                 " />
            </div>
            <label class="col-md-1 form-label text-right  ">@Html.DisplayNameFor(model => model.Manager)</label>
            <div class="col-md-3">
              <input id="@Html.IdFor(model => model.Manager)"
                     name="@Html.NameFor(model => model.Manager)"
                     value="@Html.ValueFor(model => model.Manager)"
                     tabindex="1"
                     class="easyui-textbox"
                     style="width:100%"
                     type="text"
                     data-options="prompt:'@Html.DisplayNameFor(model => model.Manager)',
								 required:false,
                                 validType: 'length[0,10]'
                                 " />
            </div>
            <label class="col-md-1 form-label text-right text-danger">@Html.DisplayNameFor(model => model.CompanyId)</label>
            <div class="col-md-3">
              <input id="@Html.IdFor(model => model.CompanyId)"
                     name="@Html.NameFor(model => model.CompanyId)"
                     value="@Html.ValueFor(model => model.CompanyId)"
                     tabindex="2" required
                     class="easyui-combobox"
                     style="width:100%"
                     data-options="prompt:'@Html.DisplayNameFor(model => model.CompanyId)' ,
						required:true ,
						valueField: 'Id',
						textField:  'Name' ,
                        validateOnCreate:false,
                        validateOnBlur:true,
                        validType:'combocheck[\'#CompanyId\',\'请选择CompanyId\']',
						url: '/Departments/GetCompanies' ,
						onSelect: function(item){
						  //console.log(item);
				        }">
            </div>
          </div>

        </fieldset>
      </form>
    </div>
  </div>
<div id="windowfooter" style="padding:5px;">&nbsp;</div>
<!--begin popup detailview javascript block -->
<script type="text/javascript">
    //判断新增编辑状态
    var MODELSTATE = 'Added';
    var departmentid = null;
    function opendepartmentdetailwindow(data,state) {
         MODELSTATE = state;
         initdepartmentdetailview();
         departmentid = (data.Id || 0);
         $("#departmentdetailwindow").window("open");
         $('#department_form').form('reset');
         $('#department_form').form('load', data);
             }
  //删除当前记录
  function deletedepartmentitem() {
    $.messager.confirm('确认', '你确定要删除该记录?', result => {
      if (result) {
        const url = `/Departments/Delete/${departmentid}`;
        $.get(url).done(res => {
          if (res.success) {
            toastr.success("删除成功");
            $dg.datagrid('reload');
            $("#detailswindow").window("close");
          } else {
            $.messager.alert("错误", res.err, "error");
          }
        });
      }
    });
  }
    //async 保存数据
    async function savedepartmentitem() { 
      const $departmentform = $('#department_form');
      if ($departmentform.form('enableValidation').form('validate')) {
            let department = $departmentform.serializeJSON();
            let url = '/Departments/Edit';
            //判断是新增或是修改方法
            if (MODELSTATE === 'Added') {
                url = '/Departments/Create';
            }
            var token = $('input[name="__RequestVerificationToken"]', $departmentform).val();
            $.messager.progress({ title: '请等待', msg: '正在保存数据...', interval:200});
            $.ajax({
                    type: "POST",
                    url: url,
                    data: {
                        __RequestVerificationToken: token,
                        department:department
                    },
                    dataType: 'json',
                    contentType: 'application/x-www-form-urlencoded; charset=utf-8'
                })
                .done(response => {
                    $.messager.progress('close');
                    if (response.success) {
                        hook = false;
                        $departmentform.form('disableValidation');
                        $dg.datagrid('reload');
                        $('#departmentdetailwindow').window("close");
                        toastr.success("保存成功");  
                    } else {
                        $.messager.alert("错误",   response.err, "error");
                    }
                    })
                .fail((jqXHR, textStatus, errorThrown) => {
                       $.messager.progress('close');
                       $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
                    });
        }
    }
    //关闭窗口
    function closedepartmentdetailwindow() {
        $('#departmentdetailwindow').window('close');
    }
    //todo
    function todo() {
         console.log('todo.....');
    }
     //判断是否有没有保存的记录
     function departmenthasmodified() {
            return hook;

     }


function initdepartmentdetailview() {
  //判断是否显示功能按钮
  if (MODELSTATE === 'Added') {
    $('#deleteitem-btn-group').hide();
  } else {
    $('#deleteitem-btn-group').show();
  }
 
//回车光标移动到下个输入控件
    //CompanyId默认外键使用combobox,也可以使用combogrid
	$('#CompanyId').combobox('textbox').bind('keydown', function (e) {
      if (e.keyCode == 13) {
        $(e.target).emulateTab();
      }
    });
}
</script>

