﻿@model WebApp.Models.CustomerWaterMeter
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
      
       <!--用水单位-->
       <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.CustomerId)</label>
   	        @Html.DropDownListFor(model => model.CustomerId, ViewBag.CustomerId as List<SelectListItem>, htmlAttributes: new { @class = "form-control" }) 
       </div>

        <!--表号-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.meterId)</label>
			@Html.EditorFor(x => x.meterId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.meterId) } })
      
         </div>

		<!--用水定额(月)-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Quota)</label>
            @Html.EditorFor(x => x.Quota, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Quota) } })

        </div>

		
      <!--是否计费-->
      <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
              <label class="form-label text-danger">@Html.DisplayNameFor(model => model.IsFee)</label>
              <div class="custom-control custom-checkbox">
                 <input id="@Html.IdFor(model => model.IsFee)"
                       name="@Html.NameFor(model => model.IsFee)"
                       value="true" @(Model.IsFee ? "checked=\"checked\"" : "")
                       class="custom-control-input"
                       tabindex="6"
                       type="checkbox" />
                <label class="custom-control-label" for="@Html.IdFor(model => model.IsFee)">@Html.DisplayNameFor(model => model.IsFee)</label>
            </div>
      </div>

		<!--折扣-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Discount)</label>
            @Html.EditorFor(x => x.Discount, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Discount) } })

        </div>

        <!--备注-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Remark)</label>
			@Html.EditorFor(x => x.Remark, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Remark) } })
      
         </div>

        <!--单位名称-->
        <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.CustomerName)</label>
			@Html.EditorFor(x => x.CustomerName, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.CustomerName) } })
      
         </div>

		
      <!--是否删除-->
      <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
              <label class="form-label text-danger">@Html.DisplayNameFor(model => model.IsDelete)</label>
              <div class="custom-control custom-checkbox">
                 <input id="@Html.IdFor(model => model.IsDelete)"
                       name="@Html.NameFor(model => model.IsDelete)"
                       value="true" @(Model.IsDelete ? "checked=\"checked\"" : "")
                       class="custom-control-input"
                       tabindex="6"
                       type="checkbox" />
                <label class="custom-control-label" for="@Html.IdFor(model => model.IsDelete)">@Html.DisplayNameFor(model => model.IsDelete)</label>
            </div>
      </div>

       <!--注册日期-->
       <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.RegisterDate)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.RegisterDate, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.RegisterDate ) } })
               <div class="input-group-append">
                                                            <span class="input-group-text fs-xl">
                                                                <i class="fal fa-calendar-alt"></i>
                                                            </span>
                                                        </div>
			 </div>
         </div>

       <!--截止日期-->
       <div class="col-xs-12 col-sm-6 col-md-3 col-lg-2">
            <label class="form-label ">@Html.DisplayNameFor(model => model.DeleteDate)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.DeleteDate, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.DeleteDate ) } })
               <div class="input-group-append">
                                                            <span class="input-group-text fs-xl">
                                                                <i class="fal fa-calendar-alt"></i>
                                                            </span>
                                                        </div>
			 </div>
         </div>

	    
</div>

