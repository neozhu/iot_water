  <script type="text/javascript">

    function loadtreedata(isdelete) {
      if (isdelete == 0) {
        $.get('/CustomerWaterMeters/GetCategoryTreeData').done(res => {
          const data = res;
          $('#tree').treeview({
            expandIcon: "fal fa-plus",
            collapseIcon: "fal  fa-minus",
            levels: 1,
            data: data.list,
            onNodeSelected: function (event, data) {
              console.log(event, data)
              //var url = '/WaterMeters/GetData?allmeterid=' + data.data;
              //$dg.datagrid('load', url);
              $dg.datagrid('removeFilterRule');
              $dg.datagrid('addFilterRule', {
                field: 'Id',
                op: 'includes',
                value: data.data
              });
              $dg.datagrid('doFilter');
            }
          });
        });
      } else {
        $.get('/CustomerWaterMeters/GetCategoryTreeData?isdelete=1').done(res => {
          const data = res;
          $('#tree').treeview({
            expandIcon: "fal fa-plus",
            collapseIcon: "fal  fa-minus",
            levels: 1,
            data: data.list,
            onNodeSelected: function (event, data) {
              console.log(event, data)
              //var url = '/WaterMeters/GetData?allmeterid=' + data.data;
              //$dg.datagrid('load', url);
              $dg.datagrid('removeFilterRule');
              $dg.datagrid('addFilterRule', {
                field: 'Id',
                op: 'includes',
                value: data.data
              });
              $dg.datagrid('doFilter');
            }
          });
        });
      }
    }
    $(() => {
      loadtreedata(0);
    })

  </script>

  <script type="text/javascript">
      //是否强制从后台取值
      const REQUIRBACKEND = false;
      //是否开启行内编辑
      const EDITINLINE = true;
      var customerwatermeter = {};

      //下载Excel导入模板
      function downloadtemplate() {
          //默认模板路径存放位置
          const url = '/FileUpload/Download?file=/ExcelTemplate/CustomerWaterMeter.xlsx';
          $.fileDownload(url)
           .done(() => {
                    //console.log('file download a success!');
                    toastr.success('模板下载完成!');
                })
           .fail(() => {
               $.messager.alert('下载模板失败','没有下载到导入模板[CustomerWaterMeter.xlsx]文件!','error');
            });
       }

       //执行导出下载Excel
       function exportexcel() {
                const filterRules = JSON.stringify($dg.datagrid('options').filterRules);
                //console.log(filterRules);
                $.messager.progress({ title: '正在执行导出!' });
                let formData = new FormData();
                formData.append('filterRules', filterRules);
                formData.append('sort', 'Id');
                formData.append('order', 'asc');
                $.postDownload('/CustomerWaterMeters/ExportExcel', formData).then(res => {
                    $.messager.progress('close');
                    toastr.success('导出成功!');
                }).catch(err => {
                    //console.log(err);
                    $.messager.progress('close');
                    $.messager.alert('导出失败', err.statusText, 'error');
                });

        }

    var editIndex = undefined;

    function reloadAll() {
      loadtreedata(1);
      $dg.datagrid('removeFilterRule');
      $dg.datagrid('uncheckAll');
      $dg.datagrid('reload');
    }
       //重新加载数据
    function reload() {
      //$dg.datagrid('removeFilterRule');

                $dg.datagrid('uncheckAll');
                $dg.datagrid('reload');

       }
      //关闭编辑状态
      function endEditing() {
            if (editIndex === undefined) {
                return true;
            }
            if ($dg.datagrid('validateRow', editIndex)) {
                $dg.datagrid('endEdit', editIndex);
                return true;
            } else {
                const invalidinput = $('input.validatebox-invalid',$dg.datagrid('getPanel'));
                const fieldnames = invalidinput.map((index, item) => {
                  return $(item).attr('placeholder') || $(item).attr('id');
                });
                $.messager.alert('提示', `${Array.from(fieldnames)} 输入有误.`, 'error');
                return false;
            }
        }
    //单击列开启编辑功能
    function onClickCell(index, field) {
        customerwatermeter = $dg.datagrid('getRows')[index];
        const _actions = ['action', 'ck'];
        if (!EDITINLINE || $.inArray(field, _actions) >= 0) {
                return;
        }
        if (editIndex !== index) {
            if (endEditing()) {
                $dg.datagrid('selectRow', index)
                   .datagrid('beginEdit', index);
                hook = true;
                editIndex = index;
                const ed = $dg.datagrid('getEditor', { index: index, field: field });
                if (ed) {
                        ($(ed.target).data('textbox') ? $(ed.target).textbox('textbox') : $(ed.target)).focus();
                }
            } else {
                $dg.datagrid('selectRow', editIndex);
            }
        }
    }
    //新增记录
    async function append() {
       customerwatermeter = { Quota: 0,
IsFee: false,
Discount: 0,
RegisterDate: moment().format('YYYY-MM-DD HH:mm:ss'),
 };
        //需要后台创建对象
       if (REQUIRBACKEND) {
         customerwatermeter = await $.get('/CustomerWaterMeters/NewItem');
       }
        if (!EDITINLINE) {
           //弹出新增窗口
           opencustomerwatermeterdetailwindow(customerwatermeter, 'Added');
        } else {
            if (endEditing()) {
                //对必填字段进行默认值初始化
                $dg.datagrid('insertRow',
                              {
                                  index: 0,
                                  row: customerwatermeter
                               });
                editIndex = 0;
                $dg.datagrid('selectRow', editIndex)
                    .datagrid('beginEdit', editIndex);
                hook = true;
            }
        }
    }
    //删除编辑的行
    function removeit() {
       if (EDITINLINE) {
          if (editIndex !== undefined) {
             $dg.datagrid('cancelEdit', editIndex)
                .datagrid('deleteRow', editIndex);
               editIndex = undefined;
               hook = true;
               $("button[name*='savebutton']").prop('disabled', false);
               $("button[name*='cancelbutton']").prop('disabled', false);
           }else{
              const rows = $dg.datagrid('getChecked');
              rows.slice().reverse().forEach(row => {
                const rowindex = $dg.datagrid('getRowIndex', row);
                $dg.datagrid('deleteRow', rowindex);
                hook = true;
                $("button[name*='savebutton']").prop('disabled', false);
                $("button[name*='cancelbutton']").prop('disabled', false);
            });
           }
        } else {
          deletechecked();
        }
    }
  //删除该行
  function deleteRow(id) {
    $.messager.confirm('确认', '你确定要删除该记录?', result => {
      if (result) {
        dodeletechecked([id]);
      }
     });
  }
    //删除选中的行
    function deletechecked() {
        const id = $dg.datagrid('getChecked').filter(item=>item.Id!=null && item.Id > 0).map(item => {
                   return item.Id;
                });;
        if (id.length > 0) {
           $.messager.confirm('确认', `你确定要删除这 <span class='badge badge-icon position-relative'>${id.length} </span> 行记录?`, result => {
                if (result) {
                    dodeletechecked(id);
                    }
                });
         } else {
                $.messager.alert('提示', '请先选择要删除的记录!','question');
         }
     }
    //执行删除
    function dodeletechecked(id){
       $.post('/CustomerWaterMeters/DeleteChecked', { id: id })
                         .done(response => {
                                if (response.success) {
                                    toastr.error(`成功删除[${id.length}]行记录`);
                                    reload();
                                } else {
                                    $.messager.alert('错误', response.err,'error');
                                }
                          })
                          .fail((jqXHR, textStatus, errorThrown) => {
                             $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
                          });
    }
    //提交保存后台数据库
    function accept() {
      if (endEditing()) {
        if ($dg.datagrid('getChanges').length > 0) {
          const inserted = $dg.datagrid('getChanges', 'inserted').map(item => {
          item.TrackingState = 1;
          return item;
        });
        const updated = $dg.datagrid('getChanges', 'updated').map(item => {
          item.TrackingState = 2
          return item;
        });
        const deleted = $dg.datagrid('getChanges', 'deleted').map(item => {
          item.TrackingState = 3
          return item;
        });
        //过滤已删除的重复项
        const changed = inserted.concat(updated.filter(item => {
            return !deleted.includes(item);
          })).concat(deleted);
        //console.table(changed);
        $.messager.progress({ title: '请等待', msg: '正在保存数据...', interval:200});
        $.post('/CustomerWaterMeters/SaveData', {customerwatermeters:changed})
                     .done(response => {
                     $.messager.progress('close');
                           //console.log(response);
                           if (response.success) {
                               toastr.success('保存成功');
                               $dg.datagrid('acceptChanges');
                               reload();
                               hook = false;
                           } else {
                               $.messager.alert('错误', response.err ,'error');
                           }
                        })
                      .fail((jqXHR, textStatus, errorThrown) => {
                        $.messager.progress('close');
                        $.messager.alert('异常', `${jqXHR.status}: ${jqXHR.statusText} `, 'error');
                      });
                }
            }
    }
    function reject() {
        $dg.datagrid('rejectChanges');
        editIndex = undefined;
        hook = false;
    }
    function getChanges() {
        const rows = $dg.datagrid('getChanges');
        //console.log(rows.length + ' rows are changed!');
    }
    //弹出明细信息
    async function showdetailswindow(id,index) {
        const customerwatermeter = $dg.datagrid('getRows')[index];
        if (REQUIRBACKEND) {
           customerwatermeter = await $.get('/CustomerWaterMeters/GetItem/' + id);
        }
        opencustomerwatermeterdetailwindow(customerwatermeter,'Modified');
    }

    //初始化定义datagrid
    var $dg = $('#customerwatermeters_datagrid');
    $(() => {
      //定义datagrid结构
      $dg.datagrid({
        height: 687,
        pageSize: 15,
        rownumbers: true,
        checkOnSelect: false,
        selectOnCheck: false,
        idField: 'Id',
        sortName: 'Id',
        sortOrder: 'desc',
        remoteFilter: true,
        singleSelect: false,
      
        method: 'post',
        onClickCell: onClickCell,
        pagination: true,
        clientPaging: false,
        striped: true,
        pageList: [15, 20, 50, 100, 500, 2000],
        filterRules: [{
          field: 'IsDelete',
          op: 'equal',
          value:false
        }],
        onBeforeLoad: function () {
          const that = $(this);
          document.addEventListener('smartPanel.onFullscreen', () => {
            setTimeout(() => {
              that.datagrid('resize');
            }, 200)
          })
        },
        onLoadSuccess: function (data) {
          editIndex = undefined;
          $("button[name*='deletebutton']").prop('disabled', true);
          $("button[name*='savebutton']").prop('disabled', true);
          $("button[name*='cancelbutton']").prop('disabled', true);
        },
        onCheck: function () {
          $("button[name*='deletebutton']").prop('disabled', false);
        },
        onUncheck: function () {
          const checked = $(this).datagrid('getChecked').length > 0;
          $("button[name*='deletebutton']").prop('disabled', !checked);
        },
        onSelect: function (index, row) {
          customerwatermeter = row;
        },
        onBeginEdit: function (index, row) {
          //const editors = $(this).datagrid('getEditors', index);
          const customerid = $(this).datagrid('getEditor', { index: index, field: 'CustomerId' });
          $(customerid.target).combobox('options')
            .onSelect = (item) => {
              row['CustomerId'] = item.Id;
              row['CustomerName'] = item.Name;
            };
          $(customerid.target).combobox('textbox').bind('keydown', function (e) {
            if (e.keyCode === 13) {
              $(e.target).emulateTab();
            }
          });

        },
        onEndEdit: function (index, row) {

        },
        onBeforeEdit: function (index, row) {
          editIndex = index;
          row.editing = true;
          $("button[name*='deletebutton']").prop('disabled', false);
          $("button[name*='cancelbutton']").prop('disabled', false);
          $("button[name*='savebutton']").prop('disabled', false);
          $(this).datagrid('refreshRow', index);
        },
        onAfterEdit: function (index, row) {
          row.editing = false;
          editIndex = undefined;
          $(this).datagrid('refreshRow', index);
        },
        onCancelEdit: function (index, row) {
          row.editing = false;
          editIndex = undefined;
          $("button[name*='deletebutton']").prop('disabled', true);
          $("button[name*='savebutton']").prop('disabled', true);
          $("button[name*='cancelbutton']").prop('disabled', true);
          $(this).datagrid('refreshRow', index);
        },
        frozenColumns: [[
          /*开启CheckBox选择功能*/
          { field: 'ck', checkbox: true },

        ]],
        columns: [[
          {   /*用水单位*/
            field: 'CustomerCode',
            title: '单位编号',
            width: 160,
            sortable: true,
            resizable: true,
            hidden: false,
          },
          {   /*用水单位*/
            field: 'CustomerName',
            title: '@Html.DisplayNameFor(model => model.CustomerName)',
            width: 160,
            sortable: true,
            resizable: true,
            hidden: false,
          },
          {    /*部门*/
            field: 'Dept',
            title: '@Html.DisplayNameFor(model => model.Dept)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true
          },
          {    /*表名*/
            field: 'meterName',
            title: '@Html.DisplayNameFor(model => model.meterName)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true
          },
          {    /*表号*/
            field: 'meterId',
            title: '@Html.DisplayNameFor(model => model.meterId)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true
          },
          {    /*正负项*/
            field: 'Negitive',
            title: '@Html.DisplayNameFor(model => model.Negitive)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true
          },
          {    /*用水点*/
            field: 'Points',
            title: '@Html.DisplayNameFor(model => model.Points)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true
          },
          {    /*备注*/
            field: 'Remark',
            title: '@Html.DisplayNameFor(model => model.Remark)',
            width: 260,
            hidden: false,
            sortable: true,
            resizable: true
          },
           {    /*层级*/
             field: 'Level',
            title: '@Html.DisplayNameFor(model => model.Level)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true
          },
          {    /*区域*/
            field: 'ZoneName',
            title: '@Html.DisplayNameFor(model => model.ZoneName)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true
          },
          {    /*是否停用*/
            field: 'IsDelete',
            title: '是否停用',
            width: 90,
            sortable: true,
            hidden: false,
            formatter: checkboxformatter
          },
          {    /*注册日期*/
            field: 'RegisterDate',
            title: '@Html.DisplayNameFor(model => model.RegisterDate)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true,
            formatter:dateformatter
          },
          {    /*截止日期*/
            field: 'DeleteDate',
            title: '@Html.DisplayNameFor(model => model.DeleteDate)',
            width: 120,
            hidden: false,
            sortable: true,
            resizable: true,
            formatter:dateformatter
          },
        ]]
      })
       .datagrid('enableFilter', [
        {   /*是否停用*/
          field: 'IsDelete',
          type: 'booleanfilter'

        },
        {   /*用水定额(月)*/
          field: 'Quota',
          type: 'numberbox'

        },
        {   /*折扣*/
          field: 'Discount',
          type: 'numberbox'
        },
        {     /*注册日期*/
          field: 'RegisterDate',
          type: 'dateRange',
          options: {
          }
        },
        {     /*截止日期*/
          field: 'DeleteDate',
          type: 'dateRange',
          options: {
          }
        },


       ]).datagrid('load', '/CustomerWaterMeters/GetData');
    });

  </script>



}


