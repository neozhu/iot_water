
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>PrintPreview</title>
</head>
<body>

  @Html.Raw(ViewData["report"])

  <script>
    document.addEventListener("DOMContentLoaded", function () {
      window.print();
    });

  </script>
</body>
</html>
