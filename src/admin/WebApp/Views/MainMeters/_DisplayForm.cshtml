﻿@model WebApp.Models.MainMeter
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
        <!--日期-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.date)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.date, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.date ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

		<!--进水表现-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.inwater)</label>
            @Html.EditorFor(x => x.inwater, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.inwater) } })

        </div>

		<!--当天进水量-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.involume)</label>
            @Html.EditorFor(x => x.involume, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.involume) } })

        </div>

		<!--出水表现-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.outwater)</label>
            @Html.EditorFor(x => x.outwater, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.outwater) } })

        </div>

		<!--当天用水量-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.outvolume)</label>
            @Html.EditorFor(x => x.outvolume, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.outvolume) } })

        </div>

        <!--备注-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.remark)</label>
			@Html.EditorFor(x => x.remark, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.remark) } })
      
         </div>

	    
</div>

