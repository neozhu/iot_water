﻿@model WebApp.Models.AlarmLog
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
        <!--发生时间-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.InitDateTime)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.InitDateTime, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.InitDateTime ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

        <!--对象-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.DeviceId)</label>
			@Html.EditorFor(x => x.DeviceId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.DeviceId) } })
      
         </div>

        <!--报警内容-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Content)</label>
			@Html.EditorFor(x => x.Content, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Content) } })
      
         </div>

        <!--状态-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Status)</label>
			@Html.EditorFor(x => x.Status, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Status) } })
      
         </div>

        <!--类型-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Type)</label>
			@Html.EditorFor(x => x.Type, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Type) } })
      
         </div>

        <!--报警等级-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Level)</label>
			@Html.EditorFor(x => x.Level, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Level) } })
      
         </div>

        <!--提交人-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.User)</label>
			@Html.EditorFor(x => x.User, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.User) } })
      
         </div>

        <!--处理人-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.ToUser)</label>
			@Html.EditorFor(x => x.ToUser, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.ToUser) } })
      
         </div>

       <!--开始处理时间-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.BeginDateTime)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.BeginDateTime, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.BeginDateTime ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

       <!--完成时间-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.CompletedDateTime)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.CompletedDateTime, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.CompletedDateTime ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

        <!--处理结果-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Result)</label>
			@Html.EditorFor(x => x.Result, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Result) } })
      
         </div>

	    
</div>

