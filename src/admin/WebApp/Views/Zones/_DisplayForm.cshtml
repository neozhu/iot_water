﻿@model WebApp.Models.Zone
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
         <!--区域名称-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Name)</label>
			@Html.EditorFor(x => x.Name, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Name) } })
      
         </div>

        <!--描述-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Description)</label>
			@Html.EditorFor(x => x.Description, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Description) } })
      
         </div>

        <!--geo数据-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.GeoJSON)</label>
			@Html.EditorFor(x => x.GeoJSON, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.GeoJSON) } })
      
         </div>

	    
</div>

