﻿@model WebApp.Models.BillDetail
  <div class="form-row">
   @Html.HiddenFor(x=>x.Id)
      
       <!--BillId-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.BillId)</label>
   	        @Html.DropDownListFor(model => model.BillId, ViewBag.BillId as List<SelectListItem>, htmlAttributes: new { @class = "form-control" }) 
       </div>

        <!--表名-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.MeterName)</label>
			@Html.EditorFor(x => x.MeterName, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.MeterName) } })
      
         </div>

        <!--表序号-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.LineNo)</label>
			@Html.EditorFor(x => x.LineNo, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.LineNo) } })
      
         </div>

        <!--表号-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.MeterId)</label>
			@Html.EditorFor(x => x.MeterId, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.MeterId) } })
      
         </div>

        <!--出线名称-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.MeterName1)</label>
			@Html.EditorFor(x => x.MeterName1, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.MeterName1) } })
      
         </div>

        <!--安装位置-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.MeterPoint)</label>
			@Html.EditorFor(x => x.MeterPoint, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.MeterPoint) } })
      
         </div>

        <!--正负项-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Negitive)</label>
			@Html.EditorFor(x => x.Negitive, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Negitive) } })
      
         </div>

		<!--占比-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Ratio)</label>
            @Html.EditorFor(x => x.Ratio, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Ratio) } })

        </div>

		<!--用水量(m3)-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.Water)</label>
            @Html.EditorFor(x => x.Water, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Water) } })

        </div>

		<!--上个月用水量(m3)-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.LastWater)</label>
            @Html.EditorFor(x => x.LastWater, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.LastWater) } })

        </div>

		<!--环比(%)-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.PerCent)</label>
            @Html.EditorFor(x => x.PerCent, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.PerCent) } })

        </div>

		<!--实际用水量(m3)-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label text-danger">@Html.DisplayNameFor(model => model.ActualWater)</label>
            @Html.EditorFor(x => x.ActualWater, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.ActualWater) } })

        </div>

       <!--期初日期-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.WaterDt1)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.WaterDt1, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.WaterDt1 ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

		<!--期初水量(m3)-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Water1)</label>
            @Html.EditorFor(x => x.Water1, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Water1) } })

        </div>

       <!--期末日期-->
       <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.WaterDt2)</label>
            <div class="input-group">
			  @Html.EditorFor(x => x.WaterDt2, 
                         new { htmlAttributes = new { @class = "form-control datepicker hasDatepicker",
                               placeholder = Html.DisplayNameFor(x => x.WaterDt2 ) } })
               <span class="input-group-addon"><i class="fa fa-calendar"></i></span>
			 </div>
         </div>

		<!--期末水量(m3)-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Water2)</label>
            @Html.EditorFor(x => x.Water2, new { htmlAttributes = new { @class = "form-control",@type="number", placeholder = Html.DisplayNameFor(x => x.Water2) } })

        </div>

        <!--备注-->
        <div class="col-xs-12 col-md-6">
            <label class="form-label ">@Html.DisplayNameFor(model => model.Remark)</label>
			@Html.EditorFor(x => x.Remark, new { htmlAttributes = new { @class = "form-control", placeholder = Html.DisplayNameFor(x => x.Remark) } })
      
         </div>

	    
</div>

